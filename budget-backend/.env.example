# ─── CoupleFlow Backend Environment ────────────────────────────
# Copy this file to .env and fill in your values.

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=youruser
PG_PASS=yourpassword
PG_DB=budget_db

# Plaid (https://dashboard.plaid.com)
# Environment options: sandbox (testing), development (staging), production (live)
# See internal/plaid/environments.md for detailed configuration guide
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Optional: Webhook URL for receiving Plaid events (required for production)
PLAID_WEBHOOK_URL=

# Auth secrets (generate with: openssl rand -hex 32)
JWT_SECRET=
SESSION_SECRET=

# OAuth — Google (from Google Cloud Console → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=

# OAuth — Apple (your app's bundle identifier)
APPLE_BUNDLE_ID=com.github.aboogie.budgetapp

# Anthropic (Claude AI Assistant)
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Server
PORT=8080
